#!/usr/bin/env bash
# =============================================================================
# rote — terse CLI for the local Rote API.
#
# Designed for minimum token usage by an LLM caller: tab-separated output, no
# headers, no decorative ANSI, no "successfully" lines.  Default exit code is
# the API's HTTP status mapped to standard shell semantics.
#
# Subcommands
# -----------
#   rote find <query>                   semantic search for a script
#   rote run <name> [-- script-args...] execute a script in the library
#   rote show <name>                    one script's frontmatter
#   rote list                           list all scripts (terse)
#
#   rote vault list                     list secret NAMES + byte sizes
#   rote vault has KEY [KEY...]         which keys exist
#   rote vault inject --env-file P --key K [--key K...] [--label L]
#                                             inject named secrets into a .env
#                                             (Claude never sees the values)
#
#   rote ap find <query>                semantic search anti-patterns
#   rote ap list                        list anti-patterns
#   rote ap add <slug> <title> <symptom> <remedy> [--cost <text>]
#                                             record (or bump hit-count of) one
#
#   rote delegate list                  list delegates + per-cap stats
#   rote delegate show NAME             one delegate + recent log
#   rote delegate best CAPABILITY       best enabled delegate for CAP
#                                             (exits 4 if none qualify)
#   rote delegate log NAME CAP OUTCOME --task "summary"
#                                             [--latency-ms N] [--saved N] [--notes T]
#   rote delegate set-url NAME URL      patch endpoint URL
#   rote delegate enable NAME           flip enabled=true
#   rote delegate disable NAME          flip enabled=false (soft-delete)
#   rote delegate dispatch NAME CAP -- <args>
#                                             route to the right dispatch-to-*
#                                             script by delegate kind; logs
#                                             outcome + latency automatically
#
#   rote audit [N]                      recent N audit events (default 20)
#   rote health                         api health check
#   rote up                             start the api (if down)
#   rote gui                            print the GUI URL (open in browser)
#   rote verify                         end-to-end smoke test of the whole
#                                             context system (PASS/FAIL/WARN)
#   rote bootstrap                      fresh-machine zero-to-ready:
#                                             backend up, MCP venv, client
#                                             configs, verify
#   rote mcp-install                    detect-and-write MCP client
#                                             configs (Claude Desktop, Cursor,
#                                             Continue.dev, Cline)
#
# Env
#   API   default http://127.0.0.1:5572
#
# Deps: curl, jq.  On Debian/Ubuntu: `sudo apt-get install -y jq`.
# =============================================================================
set -euo pipefail

API="${API:-http://127.0.0.1:5572}"
HERE="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
LIB_ROOT="$(dirname "$HERE")"

die() { echo "${1:-error}" >&2; exit "${2:-1}"; }
have() { command -v "$1" >/dev/null; }

have curl || die "curl required (install with: sudo apt-get install -y curl)" 4
have jq   || die "jq required (install with: sudo apt-get install -y jq) — or open the GUI at $API/" 4

# Cheap probe; many subcommands fall through to it.
api_up() { curl -fsS -o /dev/null -m 2 "$API/healthz" 2>/dev/null; }

need_api() {
    api_up && return 0
    die "api down at $API — start: $LIB_ROOT/server/start.sh" 4
}

api() {
    # usage: api METHOD PATH [json-body]
    local m="$1" p="$2" body="${3:-}"
    if [[ -n "$body" ]]; then
        curl -fsS -X "$m" -H "Content-Type: application/json" --data "$body" "$API$p"
    else
        curl -fsS -X "$m" "$API$p"
    fi
}

# -----------------------------------------------------------------------------
# Scripts
# -----------------------------------------------------------------------------
cmd_list() {
    need_api
    local env_filter=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --env) env_filter="$2"; shift 2 ;;
            *) die "list: unknown arg: $1" ;;
        esac
    done
    local url="/scripts"
    [[ -n "$env_filter" ]] && url="$url?environment=$env_filter"
    api GET "$url" \
        | jq -r '.scripts[] | "\(.name)\t\(.environment)\t\(.family)\t\(.touches_secrets)\t\(.purpose)"'
}

cmd_family() {
    need_api
    local family="${1:-}"; [[ -n "$family" ]] || die "usage: rote family <family> [--env <tag>]"
    shift
    local env_filter=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --env) env_filter="$2"; shift 2 ;;
            *) die "family: unknown arg: $1" ;;
        esac
    done
    local url="/scripts/family/$family"
    [[ -n "$env_filter" ]] && url="$url?environment=$env_filter"
    api GET "$url" \
        | jq -r '
            "family:\t\(.family)",
            "best_match:\t\((.best_match // {}).name // "none")",
            (.variants[] | "variant:\t\(.name)\t\(.environment)")
        '
}

cmd_show() {
    need_api
    local name="${1:-}"; [[ -n "$name" ]] || die "usage: rote show <name>"
    api GET "/scripts/$name" \
        | jq -r '"path:\t\(.path)\npurpose:\t\(.purpose)\nwhen:\t\(.when_to_use)\nsecrets:\t\(.touches_secrets)"'
}

cmd_find() {
    need_api
    local q="$*"; [[ -n "$q" ]] || die "usage: rote find <query>"
    local body
    body=$(jq -nc --arg q "$q" '{query: $q, limit: 5}')
    api POST /scripts/search "$body" \
        | jq -r '.matches[] | "\(.name)\t\(.distance | tostring | .[0:5])\t\(.purpose)"'
}

cmd_run() {
    need_api
    local name="${1:-}"; [[ -n "$name" ]] || die "usage: rote run <name> [-- args...]"
    shift
    # Strip a leading "--" arg-separator if present so the caller can pass
    # arbitrary flags through to the script without quoting hell.
    [[ "${1:-}" == "--" ]] && shift || true

    local path
    path=$(api GET "/scripts/$name" | jq -r '.path')
    [[ -x "$path" ]] || die "script not executable: $path" 4

    # Time + capture exit code so we can log usage/failure stats.  Forwards
    # the child's stdout + stderr unchanged so the caller sees the same
    # output as if they exec'd directly.  We don't redirect anything.
    local start_ms end_ms rc
    start_ms=$(date +%s%3N)
    set +e
    "$path" "$@"
    rc=$?
    set -e
    end_ms=$(date +%s%3N)

    # Build args preview: first 200 chars of joined args
    local args_preview
    args_preview=$(printf '%s ' "$@" 2>/dev/null | cut -c1-200)

    local outcome
    if [[ "$rc" -eq 0 ]]; then
        outcome="success"
    elif [[ "$rc" -eq 124 ]]; then
        outcome="timeout"
    else
        outcome="failure"
    fi

    # POST to /scripts/<name>/runs.  Failures here are silent — we don't
    # want a logging hiccup to mask the real script's exit code.
    local body
    body=$(jq -nc \
        --arg outcome "$outcome" \
        --arg caller "cli" \
        --arg args "$args_preview" \
        --argjson rc "$rc" \
        --argjson dur "$(( end_ms - start_ms ))" \
        '{outcome: $outcome, exit_code: $rc, duration_ms: $dur,
          caller: $caller, args_preview: $args}')
    curl -fsS -X POST -H "Content-Type: application/json" \
        --data "$body" "$API/scripts/$name/runs" >/dev/null 2>&1 || true

    exit "$rc"
}

cmd_script_log() {
    # Manual outcome recording for runs Claude did via Bash directly
    # (not through cmd_run).  Useful when the rule is broken and we want
    # to keep stats honest anyway.
    need_api
    local name="${1:-}" outcome="${2:-}"
    [[ -n "$name" && -n "$outcome" ]] \
        || die "usage: rote script-log NAME OUTCOME [--duration-ms N] [--exit N] [--notes TEXT]"
    shift 2
    local duration="" exit_code="" notes="" caller="direct"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --duration-ms) duration="$2"; shift 2 ;;
            --exit)        exit_code="$2"; shift 2 ;;
            --notes)       notes="$2"; shift 2 ;;
            --caller)      caller="$2"; shift 2 ;;
            *) die "script-log: unknown arg: $1" ;;
        esac
    done
    local body
    body=$(jq -nc \
        --arg outcome "$outcome" \
        --arg caller "$caller" \
        --arg notes "$notes" \
        --argjson dur "${duration:-null}" \
        --argjson rc "${exit_code:-null}" \
        '{outcome: $outcome, caller: $caller, notes: $notes,
          duration_ms: $dur, exit_code: $rc}')
    api POST "/scripts/$name/runs" "$body" | jq -r '"\(.action)\t\(.script)\t\(.outcome)"'
}

# -----------------------------------------------------------------------------
# Vault
# -----------------------------------------------------------------------------
cmd_vault() {
    need_api
    local sub="${1:-list}"; shift || true
    case "$sub" in
        list)
            api GET /vault/keys | jq -r '.keys[] | "\(.name)\t\(.bytes)"' ;;
        has)
            [[ $# -gt 0 ]] || die "usage: rote vault has KEY [KEY...]"
            local body
            body=$(jq -nc --argjson keys "$(printf '%s\n' "$@" | jq -R . | jq -s .)" '{keys: $keys}')
            api POST /vault/has "$body" | jq -r '.exists | to_entries[] | "\(.key)\t\(.value)"' ;;
        inject)
            local env_file="" label="vault-inject"
            local -a keys=()
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --env-file) env_file="$2"; shift 2 ;;
                    --key)      keys+=("$2"); shift 2 ;;
                    --label)    label="$2"; shift 2 ;;
                    *) die "vault inject: unknown arg: $1" ;;
                esac
            done
            [[ -n "$env_file" && ${#keys[@]} -gt 0 ]] \
                || die "usage: rote vault inject --env-file P --key K [--key K...]"
            local body
            body=$(jq -nc \
                --arg env_file "$env_file" \
                --arg label "$label" \
                --argjson keys "$(printf '%s\n' "${keys[@]}" | jq -R . | jq -s .)" \
                '{env_file: $env_file, block_label: $label, keys: $keys}')
            local resp; resp=$(api POST /vault/inject "$body")
            # Terse multi-line summary: WROTE / MISSING / OK
            echo "$resp" | jq -r '
                "ok:\t\(.ok)",
                "env_file:\t\(.env_file)",
                (.wrote | length | "wrote:\t\(.)"),
                (.wrote[]? | "  +\(.name)\t\(.bytes)b"),
                (.missing | length | "missing:\t\(.)"),
                (.missing[]? | "  -\(.)")
            '
            # Exit 3 if anything was missing
            [[ "$(echo "$resp" | jq -r '.missing | length')" == "0" ]] || exit 3 ;;
        *) die "vault: subcommands: list|has|inject" ;;
    esac
}

# -----------------------------------------------------------------------------
# Anti-patterns
# -----------------------------------------------------------------------------
cmd_cmd() {
    need_api
    local sub="${1:-list}"; shift || true
    case "$sub" in
        list)
            local fam="" plat=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --family) fam="$2"; shift 2 ;;
                    --platform) plat="$2"; shift 2 ;;
                    *) die "cmd list: unknown arg: $1" ;;
                esac
            done
            local url="/commands"
            local qs=""
            [[ -n "$fam" ]] && qs="${qs}family=$fam&"
            [[ -n "$plat" ]] && qs="${qs}platform=$plat&"
            [[ -n "$qs" ]] && url="$url?${qs%&}"
            api GET "$url" | jq -r '.commands[] | "\(.family)\t\(.slug)\t\(.use_count)\t\(.name)"' ;;
        find)
            local q="" fam=""
            while [[ $# -gt 0 ]]; do
                case "$1" in --family) fam="$2"; shift 2 ;; *) q="$q $1"; shift ;; esac
            done
            q="${q# }"
            [[ -n "$q" ]] || die "usage: rote cmd find <query> [--family FAM]"
            local body
            if [[ -n "$fam" ]]; then
                body=$(jq -nc --arg q "$q" --arg f "$fam" '{query: $q, limit: 5, family: $f}')
            else
                body=$(jq -nc --arg q "$q" '{query: $q, limit: 5}')
            fi
            api POST /commands/search "$body" \
                | jq -r '.matches[] | "\(.slug)\t\(.distance | tostring | .[0:5])\t\(.family)\t\(.name)"' ;;
        show)
            local slug="${1:-}"; [[ -n "$slug" ]] || die "usage: rote cmd show <slug>"
            api GET "/commands/$slug" \
                | jq -r '
                    "name:\t\(.name)",
                    "family:\t\(.family)",
                    "platform:\t\(.platform)",
                    "equivalents:\t\(.equivalents)",
                    "use_count:\t\(.use_count)",
                    "\ncommand:\n\(.command_line)",
                    "\nwhen_to_use:\n\(.when_to_use)",
                    "\nwhen_not_to_use:\n\(.when_not_to_use)",
                    "\ngotchas:\n\(.gotchas)",
                    "\nflags:\n\(.flags_explained)",
                    "\nexamples:\n\(.examples)"
                ' ;;
        use)
            local slug="${1:-}"; [[ -n "$slug" ]] || die "usage: rote cmd use <slug>"
            shift
            local notes=""
            while [[ $# -gt 0 ]]; do
                case "$1" in --notes) notes="$2"; shift 2 ;; *) die "use: unknown arg: $1" ;; esac
            done
            api POST "/commands/$slug/use?notes=$(jq -nr --arg s "$notes" '$s | @uri')" "" \
                | jq -r '"\(.action)\t\(.slug)"' ;;
        *) die "cmd: subcommands: list|find|show|use" ;;
    esac
}

cmd_snippet() {
    need_api
    local sub="${1:-list}"; shift || true
    case "$sub" in
        list)
            local lang=""
            while [[ $# -gt 0 ]]; do
                case "$1" in --language) lang="$2"; shift 2 ;; *) die "snippet list: unknown arg: $1" ;; esac
            done
            local url="/snippets"; [[ -n "$lang" ]] && url="$url?language=$lang"
            api GET "$url" | jq -r '.snippets[] | "\(.language)\t\(.slug)\t\(.use_count)\t\(.name)"' ;;
        find)
            local q="" lang=""
            while [[ $# -gt 0 ]]; do
                case "$1" in --language) lang="$2"; shift 2 ;; *) q="$q $1"; shift ;; esac
            done
            q="${q# }"
            [[ -n "$q" ]] || die "usage: rote snippet find <query> [--language LANG]"
            local body
            if [[ -n "$lang" ]]; then
                body=$(jq -nc --arg q "$q" --arg l "$lang" '{query: $q, limit: 5, language: $l}')
            else
                body=$(jq -nc --arg q "$q" '{query: $q, limit: 5}')
            fi
            api POST /snippets/search "$body" \
                | jq -r '.matches[] | "\(.slug)\t\(.distance | tostring | .[0:5])\t\(.language)\t\(.name)"' ;;
        show)
            local slug="${1:-}"; [[ -n "$slug" ]] || die "usage: rote snippet show <slug>"
            api GET "/snippets/$slug" \
                | jq -r '"name:\t\(.name)\nlanguage:\t\(.language)\nuse_count:\t\(.use_count)\napplies_patterns:\t\(.applies_patterns)\napplies_technologies:\t\(.applies_technologies)\n",
                         "placeholders:", (.placeholders[]? | "  \(.name) — \(.description)\(if .example != "" then " (example: " + .example + ")" else "" end)"),
                         "\nbody:\n\(.body)"' ;;
        expand)
            local slug="${1:-}"; [[ -n "$slug" ]] || die "usage: rote snippet expand <slug> --VAR=value ..."
            shift
            local jq_args="" jq_obj_parts="{"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --*=*)
                        local kv="${1#--}"
                        local key="${kv%%=*}"
                        local value="${kv#*=}"
                        jq_args+=" --arg ${key} \"${value}\""
                        jq_obj_parts+="${key}: \$${key}, "
                        shift ;;
                    *) die "expand: unknown arg: $1" ;;
                esac
            done
            jq_obj_parts="${jq_obj_parts%, }}"
            local body
            body=$(eval "jq -nc $jq_args '{values: $jq_obj_parts}'")
            api POST "/snippets/$slug/expand" "$body" | jq -r '
                "remaining_placeholders:\t\(.remaining_placeholders | join(","))",
                "\n--- rendered ---\n\(.rendered)"' ;;
        use)
            local slug="${1:-}"; [[ -n "$slug" ]] || die "usage: rote snippet use <slug>"
            shift
            local notes=""
            while [[ $# -gt 0 ]]; do
                case "$1" in --notes) notes="$2"; shift 2 ;; *) die "use: unknown arg: $1" ;; esac
            done
            api POST "/snippets/$slug/use?notes=$(jq -nr --arg s "$notes" '$s | @uri')" "" \
                | jq -r '"\(.action)\t\(.slug)"' ;;
        *) die "snippet: subcommands: list|find|show|expand|use" ;;
    esac
}

