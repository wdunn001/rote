cmd_new() {
    # Scaffold a new library script with the required frontmatter pre-filled.
    # The goal: writing a library entry should cost no more keystrokes than
    # writing a one-off in /tmp.
    local name="${1:-}" purpose="${2:-}"
    [[ -n "$name" && -n "$purpose" ]] \
        || die "usage: rote new <name>[.sh|.ps1|.py|.js] \"<purpose>\" [--family <slug>] [--environment <tag>]"
    shift 2
    local family="" environment=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --family)      family="$2"; shift 2 ;;
            --environment) environment="$2"; shift 2 ;;
            *) die "new: unknown arg: $1" ;;
        esac
    done
    # Default extension: .sh
    [[ "$name" == *.* ]] || name="${name}.sh"
    local stem="${name%.*}" ext="${name##*.}"
