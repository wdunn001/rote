cmd_audit() {
    need_api
    local limit="${1:-20}"
    api GET "/audit?limit=$limit" \
        | jq -r '.events[] | "\(.ts_unix_ms)\t\(.kind)\t\(.payload | tostring)"'
}

cmd_health() {
    if api_up; then
        api GET /healthz | jq -r '"\(.ok)\t\(.embed_model)\tvec=\(.sqlite_vec_version)"'
    else
        echo "down" ; exit 4
    fi
}

cmd_up() {
    if api_up; then
        echo "already up"; exit 0
    fi
    echo "starting…"
    nohup "$LIB_ROOT/server/start.sh" >>"$LIB_ROOT/server/data/server.log" 2>&1 </dev/null &
    # Poll up to 30 s
    for _ in {1..60}; do
        sleep 0.5
        api_up && { echo "up"; exit 0; }
    done
    die "did not come up in 30s — check $LIB_ROOT/server/data/server.log" 4
}

cmd_delegate() {
    need_api
    local sub="${1:-list}"; shift || true
    case "$sub" in
        list)
            api GET /delegates | jq -r '
                .delegates[] |
                "\(.name)\t\(.kind)\t\(if .enabled then "on" else "off" end)\t" +
                ((.capabilities // []) | map(. as $c |
                    (((.. | objects | select(.capability == $c)) // {success_rate: null, n: 0})
                    | if .success_rate then "\($c)=\((.success_rate*100|floor))%/\(.n)" else "\($c)" end)
                ) | join(","))
            ' 2>/dev/null || \
            # Fallback if jq path expression chokes on the nested form: simpler row
            api GET /delegates | jq -r '.delegates[] | "\(.name)\t\(.kind)\t\(if .enabled then "on" else "off" end)\t\(.capabilities|join(","))"' ;;
        show)
            local name="${1:-}"; [[ -n "$name" ]] || die "usage: rote delegate show NAME"
            api GET "/delegates/$name" | jq -r '
                "name:\t\(.name)",
                "kind:\t\(.kind)",
                "enabled:\t\(.enabled)",
                "contact:\t\(.contact | tostring)",
                "capabilities:\t\(.capabilities | join(","))",
                "notes:\t\(.notes)",
                (.stats.per_capability[]? | "stat:\t\(.capability)\t\((.success_rate*100|floor))%/\(.n) avg_lat=\(.avg_latency_ms // "null")ms saved=\(.token_savings)"),
                (.recent_log[]? | "log:\t\(.ts_unix_ms)\t\(.capability)\t\(.outcome)\t\(.task_summary)")
            ' ;;
        best)
            local cap="${1:-}"; [[ -n "$cap" ]] || die "usage: rote delegate best CAPABILITY"
            local resp; resp=$(api GET "/delegates/best?capability=$cap")
            if [[ "$(echo "$resp" | jq -r '.best')" == "null" ]]; then
                echo "no qualified delegate for: $cap" >&2; exit 4
            fi
            echo "$resp" | jq -r '
                .best |
                "name:\t\(.name)\nkind:\t\(.kind)\ncontact:\t\(.contact | tostring)\nsuccess_rate:\t\((.success_rate*100|floor))%\nattempts:\t\(.attempts)"
            ' ;;
        log)
            local name="${1:-}" cap="${2:-}" outcome="${3:-}"
            [[ -n "$name" && -n "$cap" && -n "$outcome" ]] \
                || die "usage: rote delegate log NAME CAPABILITY OUTCOME [--task T] [--latency-ms N] [--saved N] [--notes T]"
            shift 3
            local task="" latency="" saved="" notes=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --task)       task="$2"; shift 2 ;;
                    --latency-ms) latency="$2"; shift 2 ;;
                    --saved)      saved="$2"; shift 2 ;;
                    --notes)      notes="$2"; shift 2 ;;
                    *) die "log: unknown arg: $1" ;;
                esac
            done
            [[ -n "$task" ]] || die "log: --task required"
            local body
            body=$(jq -nc \
                --arg d "$name" --arg c "$cap" --arg o "$outcome" --arg t "$task" \
                --arg n "$notes" \
                --argjson lat "${latency:-null}" --argjson sv "${saved:-null}" \
                '{delegate: $d, capability: $c, outcome: $o, task_summary: $t,
                  latency_ms: $lat, token_savings: $sv, notes: $n}')
            api POST /delegations "$body" | jq -r '"\(.action)\t\(.delegate)\t\(.outcome)"' ;;
        set-url)
            local name="${1:-}" url="${2:-}"
            [[ -n "$name" && -n "$url" ]] || die "usage: rote delegate set-url NAME URL"
            local body
            body=$(jq -nc --arg u "$url" '{contact: {url: $u}}')
            api PATCH "/delegates/$name" "$body" | jq -r '"\(.name)\t\(.action)"' ;;
        enable|disable)
            local name="${1:-}"; [[ -n "$name" ]] || die "usage: rote delegate $sub NAME"
            local body
            body=$(jq -nc --argjson e "$([[ $sub == enable ]] && echo true || echo false)" '{enabled: $e}')
            api PATCH "/delegates/$name" "$body" | jq -r '"\(.name)\t\(.action)"' ;;
        dispatch)
            # Pick the right dispatcher by delegate kind.  Caller passes the
            # delegate name + capability + the dispatcher's own flags after a
            # `--` separator; everything after `--` is forwarded verbatim.
            local name="${1:-}" cap="${2:-}"
            [[ -n "$name" && -n "$cap" ]] \
                || die "usage: rote delegate dispatch NAME CAPABILITY -- <dispatcher args>"
            shift 2
            [[ "${1:-}" == "--" ]] && shift || true
            local kind
            kind=$(api GET "/delegates/$name" | jq -r '.kind')
            case "$kind" in
                llm)
                    # Ollama vs sglang both kind=llm; disambiguate by delegate name.
                    if [[ "$name" == *sglang* ]]; then
                        exec "$LIB_ROOT/scripts/dispatch-to-sglang.sh" \
                            --delegate "$name" --capability "$cap" "$@"
                    else
                        exec "$LIB_ROOT/scripts/dispatch-to-ollama.sh" \
                            --delegate "$name" --capability "$cap" "$@"
                    fi ;;
                mcp)
                    exec "$LIB_ROOT/scripts/dispatch-to-metamcp.sh" \
                        --delegate "$name" --capability "$cap" "$@" ;;
                *) die "no dispatcher for delegate kind: $kind" ;;
            esac ;;
        *) die "delegate: subcommands: list|show|best|log|set-url|enable|disable|dispatch" ;;
    esac
}

