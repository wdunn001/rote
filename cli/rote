cmd_ap() {
    need_api
    local sub="${1:-list}"; shift || true
    case "$sub" in
        list)
            api GET /anti-patterns \
                | jq -r '.anti_patterns[] | "\(.slug)\t\(.hit_count)\t\(.title)"' ;;
        find)
            local q="$*"; [[ -n "$q" ]] || die "usage: rote ap find <query>"
            local body
            body=$(jq -nc --arg q "$q" '{query: $q, limit: 5}')
            api POST /anti-patterns/search "$body" \
                | jq -r '.matches[] | "\(.slug)\t\(.distance | tostring | .[0:5])\t\(.title)"' ;;
        add)
            [[ $# -ge 4 ]] || die "usage: rote ap add <slug> <title> <symptom> <remedy> [--cost text]"
            local slug="$1" title="$2" symptom="$3" remedy="$4" cost=""
            shift 4
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --cost) cost="$2"; shift 2 ;;
                    *) die "ap add: unknown arg: $1" ;;
                esac
            done
            local body
            if [[ -n "$cost" ]]; then
                body=$(jq -nc --arg slug "$slug" --arg t "$title" --arg s "$symptom" \
                              --arg r "$remedy" --arg c "$cost" \
                              '{slug:$slug, title:$t, symptom:$s, remedy:$r, token_cost:$c}')
            else
                body=$(jq -nc --arg slug "$slug" --arg t "$title" --arg s "$symptom" --arg r "$remedy" \
                              '{slug:$slug, title:$t, symptom:$s, remedy:$r}')
            fi
            api POST /anti-patterns "$body" | jq -r '"\(.action)\t\(.slug)"' ;;
        *) die "ap: subcommands: list|find|add" ;;
    esac
}

