cmd_prompt() {
    need_api
    local sub="${1:-list}"; shift || true
    case "$sub" in
        list)
            local cat=""
            while [[ $# -gt 0 ]]; do
                case "$1" in --category) cat="$2"; shift 2 ;; *) die "prompt list: unknown arg: $1" ;; esac
            done
            local url="/prompts"; [[ -n "$cat" ]] && url="$url?category=$cat"
            api GET "$url" | jq -r '.prompts[] | "\(.category)\t\(.slug)\t\(.use_count)\t\(.name)"' ;;
        find)
            local q="" cat=""
            while [[ $# -gt 0 ]]; do
                case "$1" in --category) cat="$2"; shift 2 ;; *) q="$q $1"; shift ;; esac
            done
            q="${q# }"
            [[ -n "$q" ]] || die "usage: rote prompt find <query> [--category CAT]"
            local body
            if [[ -n "$cat" ]]; then
                body=$(jq -nc --arg q "$q" --arg c "$cat" '{query: $q, limit: 5, category: $c}')
            else
                body=$(jq -nc --arg q "$q" '{query: $q, limit: 5}')
            fi
            api POST /prompts/search "$body" \
                | jq -r '.matches[] | "\(.slug)\t\(.distance | tostring | .[0:5])\t\(.category)\t\(.name)"' ;;
        show)
            local slug="${1:-}"; [[ -n "$slug" ]] || die "usage: rote prompt show <slug>"
            api GET "/prompts/$slug" \
                | jq -r '"name:\t\(.name)\ncategory:\t\(.category)\nuse_count:\t\(.use_count)\ntags:\t\(.tags)\nwhen_to_use:\t\(.when_to_use)\n",
                         "placeholders:", (.placeholders[]? | "  \(.name) — \(.description)\(if .example != "" then " (example: " + .example + ")" else "" end)"),
                         "\n--- prompt ---\n\(.body)"' ;;
        expand)
            local slug="${1:-}"; [[ -n "$slug" ]] || die "usage: rote prompt expand <slug> --VAR=value ..."
            shift
            local jq_args="" jq_obj_parts="{"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --*=*)
                        local kv="${1#--}"
                        local key="${kv%%=*}"
                        local value="${kv#*=}"
                        jq_args+=" --arg ${key} \"${value}\""
                        jq_obj_parts+="${key}: \$${key}, "
                        shift ;;
                    *) die "expand: unknown arg: $1" ;;
                esac
            done
            jq_obj_parts="${jq_obj_parts%, }}"
            local body
            body=$(eval "jq -nc $jq_args '{values: $jq_obj_parts}'")
            api POST "/prompts/$slug/expand" "$body" | jq -r '
                "missing:\t\(.missing | join(","))",
                "\n--- expanded ---\n\(.expanded)"' ;;
        use)
            local slug="${1:-}"; [[ -n "$slug" ]] || die "usage: rote prompt use <slug>"
            shift
            local notes=""
            while [[ $# -gt 0 ]]; do
                case "$1" in --notes) notes="$2"; shift 2 ;; *) die "use: unknown arg: $1" ;; esac
            done
            api POST "/prompts/$slug/use?notes=$(jq -nr --arg s "$notes" '$s | @uri')" "" \
                | jq -r '"\(.action)\t\(.slug)"' ;;
        *) die "prompt: subcommands: list|find|show|expand|use" ;;
    esac
}

