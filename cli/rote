# Dispatch
# -----------------------------------------------------------------------------
sub="${1:-help}"; shift || true
case "$sub" in
    find)    cmd_find    "$@" ;;
    list)    cmd_list "$@" ;;
    family)  cmd_family "$@" ;;
    show)    cmd_show    "$@" ;;
    run)     cmd_run     "$@" ;;
    vault)   cmd_vault   "$@" ;;
    ap)      cmd_ap      "$@" ;;
    dp)      cmd_dp      "$@" ;;
    tech)    cmd_tech    "$@" ;;
    snippet) cmd_snippet "$@" ;;
    prompt)  cmd_prompt  "$@" ;;
    stack)   cmd_stack   "$@" ;;
    cmd)     cmd_cmd     "$@" ;;
    audit)   cmd_audit   "$@" ;;
    delegate|delegates) cmd_delegate "$@" ;;
    health)  cmd_health ;;
    up)      cmd_up ;;
    gui)     cmd_gui ;;
    verify)  cmd_verify "$@" ;;
    bootstrap) cmd_bootstrap "$@" ;;
    mcp-install) cmd_mcp_install "$@" ;;
    skills-install) cmd_skills_install "$@" ;;
    new)     cmd_new "$@" ;;
    import)  cmd_import "$@" ;;
    script-log) cmd_script_log "$@" ;;
    help|-h|--help)
        sed -n '3,32p' "$0" | sed 's/^# \{0,1\}//' ;;
    *) die "unknown subcommand: $sub (try: rote help)" ;;
esac
